# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=license_user
DB_PASSWORD=your_secure_password_here
DB_NAME=license_db
DB_ROOT_PASSWORD=your_root_password_here

# 管理员配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# API密钥配置
API_KEY=your_api_key_here

# 会话密钥（用于Flask session加密）
ADMIN_SECRET_KEY=your_secret_key_here_change_this_in_production

# ZPAY支付配置（可选）
ZPAY_PID=your_zpay_pid
ZPAY_KEY=your_zpay_key
ZPAY_API_URL=https://zpayz.cn/
ZPAY_NOTIFY_URL=http://your-domain.com/api/payment/notify
ZPAY_RETURN_URL=http://your-domain.com/client/complete_order.html
